name: Build Android APK

on:
  push:
    branches:
      - main
      - master
  workflow_dispatch:

jobs:
  build:
    name: Build APK
    runs-on: ubuntu-latest

    steps:
      - name: Checkout source
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: 'zulu'
          java-version: '21'

      - name: Delete corrupt files and clear hidden caches
        run: |
          rm -f android/gradle/wrapper/gradle-wrapper.jar
          rm -rf ~/.gradle/caches

      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v4
        with:
          gradle-version: '8.13'
          cache-disabled: true

      - name: Install dependencies
        run: |
          npm install -g npm@latest
          rm -rf package-lock.json node_modules
          npm install --include=optional

      - name: Build Web App
        run: npm run build
        env:
          NODE_ENV: production
          APP_URL: "https://ais-pre-u7un6hh2e475uaiehqhwxn-395727155540.europe-west2.run.app"
          VITE_API_URL: "https://ais-pre-u7un6hh2e475uaiehqhwxn-395727155540.europe-west2.run.app"
          VITE_APP_URL: "https://ais-pre-u7un6hh2e475uaiehqhwxn-395727155540.europe-west2.run.app"

      - name: Sync Capacitor
        run: npx cap sync android

      - name: Build APK
        working-directory: ./android
        run: gradle assembleDebug --no-daemon

      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: app-debug.apk
          path: android/app/build/outputs/apk/debug/app-debug.apk
